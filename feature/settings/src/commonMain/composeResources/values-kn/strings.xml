        <item>ಹೊಸ ಸಾಲ ಖಾತೆಗಾಗಿ ಹೇಗೆ ಅರ್ಜಿ ಸಲ್ಲಿಸುವುದು?</item>
        <item>ನನ್ನ ಪ್ರೊಫೈಲ್ ಮಾಹಿತಿಯನ್ನು ಎಲ್ಲಿದೆ ನೋಡಬಹುದು?</item>
        <item>ನನ್ನ ಉಳಿತಾಯ ಖಾತೆಗಳ ವ್ಯವಹಾರಗಳನ್ನು ಎಲ್ಲಿದೆ ನೋಡಬಹುದು?</item>
        <item>QR ಕೋಡ್ ನ ಬಳಕೆ ಏನು?</item>
        <item>QR ಕೋಡ್ ಮೂಲಕ ಲಾಭಾರ್ಥಿಯನ್ನು ಹೇಗೆ ರಚಿಸುವುದು?</item>
        <item>ಸಾಲ ಖಾತೆಗಾಗಿ ಪಾವತಿಯನ್ನು ಹೇಗೆ ಮಾಡುವುದು?</item>
    </string-array>

    <string-array name="faq_ans">
        <item>ಸಾಲ ಖಾತೆಗಾಗಿ ಅರ್ಜಿ ಸಲ್ಲಿಸಲು, ಹೋಮ್ ಸ್ಕ್ರೀನ್ ನಲ್ಲಿ ನೀಡಲಾದ "ಸಾಲಕ್ಕಾಗಿ ಅರ್ಜಿ ಸಲ್ಲಿಸಿ" ಅನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ.</item>
        <item>ನಿಮ್ಮ ಪ್ರೊಫೈಲ್ ಮಾಹಿತಿಯನ್ನು ನೋಡಲು, ಹೋಮ್ ಸ್ಕ್ರೀನ್ ನಲ್ಲಿ ಪ್ರಸ್ತುತ ಬಳಕೆದಾರ ಚಿತ್ರದ ಮೇಲೆ ಕ್ಲಿಕ್ ಮಾಡಿ.</item>
        <item>ನಿಮ್ಮ ಉಳಿತಾಯ ಖಾತೆಯ ವ್ಯವಹಾರಗಳನ್ನು ನೋಡಲು, ಖಾತೆಗಳ ವಿಭಾಗಕ್ಕೆ ನ್ಯಾವಿಗೇಟ್ ಮಾಡಿ, ಅಗತ್ಯವಿರುವ ಉಳಿತಾಯ ಖಾತೆಯನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ, ಮೇಲ್ಭಾಗದ ಬಲಕ್ಕೆ ಇರುವ ಮೂರು ಡಾಟ್ಸ್ ಅನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ ಮತ್ತು ವ್ಯವಹಾರಗಳ ಆಯ್ಕೆಯನ್ನು ಆಯ್ಕೆ ಮಾಡಿ.</item>
        <item>ಯಾವುದೇ ಸಾಲ ಅಥವಾ ಉಳಿತಾಯ ಖಾತೆಗಳಿಗಾಗಿ QR ಕೋಡ್ ಅನ್ನು ಇತರ ಬಳಕೆದಾರರೊಂದಿಗೆ ಹಂಚಿಕೊಳ್ಳಬಹುದು, ಇದು ಅವರು ಲಾಭಾರ್ಥಿಯನ್ನು ರಚಿಸಲು ಅನುಮತಿಸುತ್ತದೆ.</item>
        <item>ಲಾಭಾರ್ಥಿಯನ್ನು ರಚಿಸಲು, ಹೋಮ್ ಸ್ಕ್ರೀನ್ ನಿಂದ ಲಾಭಾರ್ಥಿ ಆಯ್ಕೆಗೆ ಹೋಗಿ ನಂತರ ಕೆಳಗಿನ ಬಲಕ್ಕೆ ಇರುವ ವೃತ್ತಾಕಾರ ಗುಂಡಿಯನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ, ಸ್ಕ್ಯಾನ್ ಆಯ್ಕೆಯನ್ನು ಆಯ್ಕೆ ಮಾಡಿ ಇದು ನಿಮ್ಮ ಸಾಧನದ ಕ್ಯಾಮೆರಾವನ್ನು ತೆರೆಯುತ್ತದೆ, ಲಾಭಾರ್ಥಿಯನ್ನು ರಚಿಸಲು ಬಯಸುವ ಇತರ ವ್ಯಕ್ತಿಯ QR ಕೋಡ್ ಅನ್ನು ಸ್ಕ್ಯಾನ್ ಮಾಡಿ, ಇತರ ಅಗತ್ಯ ವಿವರಗಳನ್ನು ತುಂಬಿದ ನಂತರ QR ಕೋಡ್ ಮೂಲಕ ಲಾಭಾರ್ಥಿಯನ್ನು ರಚಿಸಲು ಸಕ್ಷಮವಾಗುತ್ತೀರಿ.</item>
        <item>ಸಾಲ ಖಾತೆಗಾಗಿ ಪಾವತಿಯನ್ನು ಮಾಡಲು, ಖಾತೆಗಳ ವಿಭಾಗಕ್ಕೆ ನ್ಯಾವಿಗೇಟ್ ಮಾಡಿ, ಸಾಲವನ್ನು ಆಯ್ಕೆ ಮಾಡಿ ನಂತರ ನಿಮಗೆ ಅಗತ್ಯವಿರುವ ಸಾಲ ಖಾತೆಯನ್ನು ತೆರೆಯಿರಿ ಮತ್ತು ಪಾವತಿ ಮಾಡಿ ಆಯ್ಕೆಯನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ.</item>
    </string-array>

