    <!-- Faq  -->
    <string name="no_questions_found">لم يتم العثور على أسئلة</string>
    <string-array name="faq_qs">
        <item>كيف أتقدم بطلب للحصول على حساب قرض جديد؟</item>
        <item>أين يمكنني عرض معلومات ملفي الشخصي؟</item>
        <item>أين يمكنني رؤية معاملات حسابات التوفير الخاصة بي؟</item>
        <item>ما هو استخدام رمز الاستجابة السريعة (QR Code)؟</item>
        <item>كيف أنشئ مستفيدًا باستخدام رمز الاستجابة السريعة؟</item>
        <item>كيف أقوم بإجراء دفع لحساب قرض؟</item>
    </string-array>

    <string-array name="faq_ans">
        <item>لتقديم طلب للحصول على حساب قرض، انقر على "تقدم بطلب للحصول على قرض" الموجود في الشاشة الرئيسية.</item>
        <item>يمكنك عرض معلومات ملفك الشخصي من خلال النقر على صورة المستخدم الموجودة في الشاشة الرئيسية.</item>
        <item>لعرض معاملات حساب التوفير الخاص بك، انتقل إلى قسم الحسابات، انقر على حساب التوفير المطلوب، انقر على النقاط الثلاث الموجودة في الزاوية العلوية اليمنى واختر خيار المعاملات.</item>
        <item>يمكن مشاركة رمز الاستجابة السريعة لأي حساب قرض أو حساب توفير مع مستخدمين آخرين مما سيتيح لهم إنشاء مستفيد.</item>
        <item>لإنشاء مستفيد، انتقل إلى خيار المستفيد من الشاشة الرئيسية ثم انقر على الزر الدائري الموجود في الزاوية السفلية اليمنى، واختر خيار المسح الضوئي الذي يفتح كاميرا جهازك، وامسح رمز الاستجابة السريعة للشخص الآخر الذي تريد إنشاء مستفيد له، وبعد ملء التفاصيل المطلوبة الأخرى، ستتمكن من إنشاء مستفيد باستخدام رمز الاستجابة السريعة.</item>
        <item>لإجراء دفع لحساب قرض، انتقل إلى قسم الحسابات، واختر القرض ثم افتح حساب القرض المطلوب وانقر على خيار إجراء الدفع.</item>
    </string-array>

