    <!-- Faq  -->
    <string name="no_questions_found">प्रश्न आढळले नाहीत</string>
    <string-array name="faq_qs">
        <item>मी नवीन कर्ज खात्याची अर्ज कसे करू शकते?</item>
        <item>मी माझी प्रोफाइल माहिती कोठे पाहू शकतो?</item>
        <item>मी माझे सेव्हिंग्स खाते व्यवहार कोठे पाहू शकतो?</item>
        <item>QR कोडचा वापर काय आहे?</item>
        <item>QR कोड वापरून लाभार्थी कसे तयार करावे?</item>
        <item>कर्ज खात्यासाठी कसे पेमेंट करावे?</item>
    </string-array>

    <string-array name="faq_ans">
        <item>कर्ज खात्याची अर्ज करण्यासाठी, होम स्क्रीनवर उपलब्ध "कर्जाची अर्ज करा" वर क्लिक करा.</item>
        <item>तुम्ही होम स्क्रीनवर उपलब्ध वापरकर्ता प्रतिमेवर क्लिक करून तुमची प्रोफाइल माहिती पाहू शकता.</item>
        <item>तुमचे सेव्हिंग्स खाते व्यवहार पाहण्यासाठी, खाते विभागात नेव्हिगेट करा, आवश्यक सेव्हिंग्स खात्यावर क्लिक करा, शीर्ष उजव्या बाजूच्या तीन डॉट्सवर क्लिक करा आणि व्यवहार पर्याय निवडा.</item>
        <item>कोणत्याही कर्ज किंवा सेव्हिंग्स खात्यासाठी QrCode इतर वापरकर्त्यांशी सामायिक केला जाऊ शकतो ज्यामुळे ते लाभार्थी तयार करू शकतील.</item>
        <item>लाभार्थी तयार करण्यासाठी, होम स्क्रीनवरून लाभार्थी पर्यायावर जा नंतर तळाशी उजवीकडे उपलब्ध गोलाकार बटणावर क्लिक करा, स्कॅन पर्याय निवडा ज्यामुळे तुमचा डिव्हाइस कॅमेरा उघडेल, इतर व्यक्तीचा QR कोड स्कॅन करा ज्यासाठी तुम्ही लाभार्थी तयार करू इच्छिता, इतर आवश्यक तपशील भरल्यानंतर तुम्ही QR कोड वापरून लाभार्थी तयार करू शकाल.</item>
        <item>कर्ज खात्यासाठी पेमेंट करण्यासाठी, खाते विभागात नेव्हिगेट करा, कर्ज निवडा नंतर तुमचे आवश्यक कर्ज खाते उघडा आणि पेमेंट करा पर्यायावर क्लिक करा.</item>
    </string-array>

