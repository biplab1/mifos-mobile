    <!-- Faq  -->
    <string name="no_questions_found">कोई प्रश्न नहीं मिला</string>
    <string-array name="faq_qs">
        <item>मैं एक नया ऋण खाता कैसे आवेदन करूं?</item>
        <item>मैं अपनी प्रोफ़ाइल जानकारी कहां देख सकता हूं?</item>
        <item>मैं अपने बचत खाते के लेनदेन कहां देख सकता हूं?</item>
        <item>QR कोड का उपयोग क्या है?</item>
        <item>मैं QR कोड का उपयोग करके एक लाभार्थी कैसे बना सकता हूं?</item>
        <item>मैं ऋण खाते के लिए भुगतान कैसे करूं?</item>
    </string-array>

    <string-array name="faq_ans">
        <item>एक ऋण खाते के लिए आवेदन करने के लिए, मुख्य स्क्रीन पर "ऋण के लिए आवेदन करें" पर क्लिक करें।</item>
        <item>आप मुख्य स्क्रीन पर उपयोगकर्ता चित्र पर क्लिक करके अपनी प्रोफ़ाइल जानकारी देख सकते हैं।</item>
        <item>अपने बचत खाते के लेनदेन देखने के लिए, खाते अनुभाग पर जाएं, आवश्यक बचत खाते पर क्लिक करें, ऊपरी दाएं कोने में तीन बिंदुओं पर क्लिक करें और लेनदेन विकल्प चुनें।</item>
        <item>किसी भी ऋण या बचत खाते के QR कोड को अन्य उपयोगकर्ताओं के साथ साझा किया जा सकता है, जिससे वे लाभार्थी बना सकें।</item>
        <item>एक लाभार्थी बनाने के लिए, मुख्य स्क्रीन से लाभार्थी विकल्प पर जाएं फिर निचले दाएं कोने में गोल बटन पर क्लिक करें, स्कैन विकल्प चुनें जो आपके डिवाइस के कैमरे को खोलता है, दूसरे व्यक्ति के QR कोड को स्कैन करें जिसके लिए आप लाभार्थी बनाना चाहते हैं, और अन्य आवश्यक विवरण भरने के बाद, आप QR कोड का उपयोग करके लाभार्थी बना सकेंगे।</item>
        <item>ऋण खाते के लिए भुगतान करने के लिए, खाते अनुभाग पर जाएं, ऋण चुनें फिर आवश्यक ऋण खाता खोलें और भुगतान विकल्प पर क्लिक करें।</item>
    </string-array>

