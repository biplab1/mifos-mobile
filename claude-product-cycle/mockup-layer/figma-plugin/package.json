{
  "name": "mifos-mockup-generator",
  "version": "1.0.0",
  "description": "Figma plugin to generate Mifos Mobile UI mockups from specifications",
  "main": "dist/plugin.js",
  "scripts": {
    "build": "esbuild src/plugin.ts --bundle --outfile=dist/plugin.js --target=es2020",
    "watch": "esbuild src/plugin.ts --bundle --outfile=dist/plugin.js --target=es2020 --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "figma",
    "plugin",
    "mifos",
    "mockup",
    "material-design"
  ],
  "author": "Mifos Initiative",
  "license": "MPL-2.0",
  "devDependencies": {
    "@figma/plugin-typings": "^1.98.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
